2026/02/20 20:23:01 jsonrpc2: --> notif: textDocument/didOpen: {"textDocument":{"languageId":"hybroid","text":"env MyLevel as Level\r\n// Import Pewpew for convenience\r\nuse Pewpew\r\n\r\nPrint(\"Hello, Pewpew!\")\r\nPrint(\"Hybroid is a beautiful language!\")\r\nconst WIDTH = 500f\r\nconst HEIGHT = 500f\r\n\r\nconst test = 10\r\n\r\nSetLevelSize(WIDTH, HEIGHT)\r\nConfigurePlayer(0, struct{\r\n  shield = 10\r\n})\r\nlet ship = NewShip(WIDTH / 2f, HEIGHT / 2f, 0)\r\n\r\nfn randomLocation() -\u003e (fixed, fixed) {\r\n  return Fmath:RandomFixed(0f, WIDTH), Fmath:RandomFixed(0f, HEIGHT)\r\n}\r\n\r\nSetEntityMesh(NewEntity(0f, 0f), MyMesh, 0)\r\n\r\nentity ExampleEntity {\r\n  fixed x, y\r\n  fixed speed\r\n  number hp = 10\r\n\r\n  spawn(fixed x, y, speed) {\r\n    self.x = x\r\n    self.y = y\r\n    self.speed = speed\r\n  }\r\n\r\n  destroy() {\r\n    Pewpew:ExplodeEntity(self, 30)\r\n  }\r\n\r\n  Update() {\r\n    let x, y = Pewpew:GetEntityPosition(self)\r\n    x = x + 10f * speed // you can bypass writing 'self.'\r\n    Pewpew:SetEntityPosition(self, x, y)\r\n  }\r\n\r\n  fn Damage(number damage) {\r\n    hp -= damage\r\n    if hp \u003c= 0 {\r\n      destroy self()\r\n    }\r\n  }\r\n\r\n  fn DamageOtherEntity(ExampleEntity otherEntity) {\r\n    otherEntity.Damage(1)\r\n  }\r\n}\r\n\r\nlet quadro = spawn ExampleEntity(100fx, 100fx, 10fx)\r\n\r\ndestroy quadro()\r\n\r\nclass Rectangle {\r\n  number width, height\r\n\r\n  new(number width, height) {\r\n    self.width = width\r\n    self.height = height\r\n  }\r\n\r\n  fn Area() -\u003e number {\r\n    return width * height\r\n  }\r\n}\r\n\r\nlet rect = new Rectangle(100, 100)\r\n\r\nPewpew:Print(ToString(rect.Area()))\r\n\r\ntick with time {\r\n  if !IsEntityAlive(ship)\r\n    StopGame()\r\n  if time % 60 == 0 {\r\n    let x, y = randomLocation()\r\n    NewRollingCube(x, y)\r\n  }\r\n  if time % 300 == 0 {\r\n    let x, y = randomLocation()\r\n    NewMothership(x, y, MothershipType.Square, 90d)\r\n  }\r\n}","uri":